window-width = 88
window-height = 20
background-opacity = 0.95
cursor-style = block

font-family = JetBrainsMono Nerd Font
font-size = 17
font-feature = "-liga, -calt"
font-thicken = true

theme = Kanagawa Wave

# Optionally pull in machine-local overrides. The `?` prefix makes this a no-op
# on machines that don't have the file, so the shared config stays portable.
config-file = ?local
